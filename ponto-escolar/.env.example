# Ambiente da aplicação. Use "development" para execução local.
NODE_ENV=development

# Obrigatória. Porta HTTP do ponto-escolar.
PORT=3000

# Banco MySQL.
# DB_HOST, DB_USER e DB_NAME são obrigatórias.
# DB_PORT e DB_CONNECTION_LIMIT são opcionais.
# DB_PASSWORD pode ficar vazia em desenvolvimento se o MySQL local não usar senha;
# em produção, o código exige DB_PASSWORD ou DB_PASS.
DB_HOST=localhost
DB_PORT=3306
DB_USER=ponto_escolar_app
DB_PASSWORD=local-example-password-change-me
DB_NAME=ponto_escolar
DB_CONNECTION_LIMIT=10

# Aliases legados aceitos pelo código. Mantenha comentados quando usar as
# variáveis principais acima. Os scripts de banco leem DB_NAME diretamente,
# por isso prefira DB_NAME em vez de DB.
# DB_PASS=local-example-password-change-me
# DB=ponto_escolar

# JWT_SECRET, JWT_EXPIRES_IN e SESSION_SECRET são obrigatórias.
# Use secrets diferentes, com pelo menos 32 caracteres e combinação de letras
# maiúsculas, minúsculas, números e símbolos.
JWT_SECRET=Example_JWT_Only_Change_Me_2026!A7c9Z
JWT_EXPIRES_IN=8h
SESSION_SECRET=Example_Session_Only_Change_Me_2026!B8d0Y

# Opcional. O padrão do JWT de funcionário é 20m.
FUNCIONARIO_JWT_EXPIRES_IN=20m

# SCHOOL_LATITUDE, SCHOOL_LONGITUDE e ALLOWED_RADIUS_METERS são obrigatórias.
# As coordenadas abaixo são apenas exemplo; substitua pelas da escola.
SCHOOL_LATITUDE=-23.550520
SCHOOL_LONGITUDE=-46.633308
ALLOWED_RADIUS_METERS=100

# Opcional. Identifica a unidade nos dados do atalho de QR Code.
SCHOOL_UNIT_CODE=UNIDADE_DEMO

# Obrigatória. Aceita uma ou mais origens separadas por vírgula.
# O valor "*" só é aceito fora de produção.
CORS_ORIGIN=http://localhost:3000

# Opcionais. Limites do fluxo de login e registro de ponto.
POINT_RATE_LIMIT_WINDOW_MS=300000
POINT_RATE_LIMIT_MAX=500

# Integração local com o gov.br-fake.
# Client ID, client secret e redirect URI são obrigatórios e precisam coincidir
# nos dois projetos. GOVBR_FAKE_BASE_URL é opcional em desenvolvimento e usa
# http://localhost:4000 como padrão.
GOVBR_FAKE_BASE_URL=http://localhost:4000
GOVBR_FAKE_CLIENT_ID=ponto-escolar
GOVBR_FAKE_CLIENT_SECRET=local-demo-client-secret-change-me
GOVBR_FAKE_REDIRECT_URI=http://localhost:3000/auth/govbr/callback

# Autorização administrativa interna do ponto-escolar.
# Ao menos ADMIN_GOVBR_SUBS ou ADMIN_GOVBR_EMAILS deve conter um valor.
# Use vírgulas para autorizar mais de um identificador.
ADMIN_GOVBR_SUBS=tcc-demo-admin-sub-001
ADMIN_GOVBR_EMAILS=admin.local@example.invalid

# Opcional. O código aceita valores entre 10 e 15.
BCRYPT_SALT_ROUNDS=12

# Configuração alternativa para um provedor Gov.br/OIDC real.
# Remova ou esvazie GOVBR_FAKE_BASE_URL e as credenciais GOVBR_FAKE_* antes
# de ativar estas variáveis. Os endpoints e credenciais dependem do cadastro
# oficial da aplicação.
# GOVBR_AUTHORIZE_URL=https://autoridade.exemplo.invalid/authorize
# GOVBR_TOKEN_URL=https://autoridade.exemplo.invalid/token
# GOVBR_USERINFO_URL=https://autoridade.exemplo.invalid/userinfo
# GOVBR_CLIENT_ID=replace-with-issued-client-id
# GOVBR_CLIENT_SECRET=replace-with-issued-client-secret
# GOVBR_REDIRECT_URI é o alias/fallback de GOVBR_FAKE_REDIRECT_URI.
# GOVBR_REDIRECT_URI=https://app.exemplo.invalid/auth/govbr/callback
