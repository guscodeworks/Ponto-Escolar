# Simulador local e demonstrativo. Não use como serviço de produção.
NODE_ENV=development

# Opcionais. O simulador usa localhost:4000 quando não são informadas.
HOST=localhost
GOVBR_FAKE_PORT=4000

# Alias de GOVBR_FAKE_PORT aceito pelo código. GOVBR_FAKE_PORT tem precedência.
# PORT=4000

# Devem coincidir com GOVBR_FAKE_CLIENT_ID e GOVBR_FAKE_CLIENT_SECRET
# configurados no ponto-escolar.
GOVBR_FAKE_CLIENT_ID=ponto-escolar
GOVBR_FAKE_CLIENT_SECRET=local-demo-client-secret-change-me

# URLs do sistema principal usadas pelo fluxo OAuth/OIDC simulado.
PONTO_ESCOLAR_REDIRECT_URI=http://localhost:3000/auth/govbr/callback
PONTO_ESCOLAR_START_URL=http://localhost:3000/auth/govbr/login

# Identidade fictícia usada pelo simulador.
# O sub deve constar em ADMIN_GOVBR_SUBS do ponto-escolar para acesso admin.
# Use somente dados de demonstração, sem dados pessoais reais.
GOVBR_FAKE_ADMIN_SUB=tcc-demo-admin-sub-001
GOVBR_FAKE_ADMIN_NAME="Administrador Local de Exemplo"
GOVBR_FAKE_ADMIN_EMAIL=admin.local@example.invalid
